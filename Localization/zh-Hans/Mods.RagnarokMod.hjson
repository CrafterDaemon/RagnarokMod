			Tooltip: ""
		}

		RiffMusicVolume: {
			Label: 即兴演奏音乐音量
			Tooltip:
				'''
				为即兴演奏设置音量。
				设置为0将禁用即兴演奏，并且在即兴演奏开始时，播放中的音乐也不会逐渐淡出。
				'''
		}

		StartText: {
			Label: 起始讯息
			Tooltip: 启用或禁用世界进入时的欢迎文本。
		}

		RiffScreenEffectIntensity: {
			Label: 即兴演奏视觉效果强度
			Tooltip: 控制即兴演奏视觉效果强度。设置为0可禁用。
		}

		MissSoundPreset: {
			Label: 错失时机音效设置
			Tooltip: 为你错失时机的演奏选择一个音效。
		}

		CustomMissSoundPath: {
			Label: 自定义错失时机音效设置路径
			Tooltip:
				'''
				请输入您想要使用的自定义错失时机音效的模组声音路径。
				如，'RagnarokMod/Sounds/bonk'。
				必须在模组的声音文件夹中有一个对应的.ogg文件，否则可能会导致崩溃或无法正常工作
				除非将“声音预设”设置为“自定义”，否则不会执行任何操作。
				'''
		}

		MissSoundVolume: {
			Label: 错失时机音效音量设置
			Tooltip: 为错失时机音效设置音量。
		}

		MissSoundDuringRiff: {
			Label: 即兴演奏中的错失时机音效
			Tooltip: 在即兴演奏时是否播放错失时机音效。
		}

		PlaySoundDuringRiff: {
			Label: 即兴演奏中的乐器音效
			Tooltip:
				'''
				确定在即兴演奏期间是否播放乐器声音。
				设置为1表示在即兴演奏期间始终播放乐器声音，设置为-1表示在即兴演奏期间不播放声音。
				0表示仅会在特定物品（如真菌响板）的即兴演奏期间播放声音。
				'''
		}

		MeterOffsetX: {
			Label: X轴仪表设置
			Tooltip: ""
		}

		MeterOffsetY: {
			Label: Y轴仪表设置
			Tooltip: ""
