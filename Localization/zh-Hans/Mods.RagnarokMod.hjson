	ClientConfig: {
		DisplayName: 客户端设置

		Headers: {
			Audio: 音频
			UITweaks: UI 设置
			WelcomeText: 进入世界讯息
			Visual: 视效
			VisFluxMeter: Vis Flux Meter Header
