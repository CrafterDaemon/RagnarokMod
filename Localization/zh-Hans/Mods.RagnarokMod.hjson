			举起这块水晶会降低防御并增加受到的伤害
			[c/FF8C00:我未曾知晓善意。我的同辈和家庭未曾向我报以同情。]
			[c/FF8C00:我寻觅一个足以信赖之人。一个能洗净我焦虑的存在。]
			[c/FF8C00:我遇见她时，看到她光耀的笑容，方知寻觅终有结果。]
			'''
		DisplayName: 聚魂圣物
	}

	CorroslimeBass: {
		Tooltip:
			'''
			发射会弹跳的腐泥球
			右键可将泥球分裂为{0}个更小的泥球
			此过程可进行{1}次
			'''
		DisplayName: 腐泥贝斯琴
	}

	CrimslimeOboe: {
		DisplayName: 血泥双簧管
		Tooltip:
			'''
			发射黏糊糊的血泥镖
			血泥镖会在{0}秒后爆炸
			'''
	}

	StringsofOblivion: {
		DisplayName: 遗忘之弦
		Tooltip: ""
	}

	WulfrumGuitar: {
		Tooltip:
			'''
			发射会反弹的音波
			右键可使音波返回
			返回的音波会无视物块
			'''
		DisplayName: 钨钢吉他
	}

	MenuMusicBox: {
		DisplayName: 音乐盒（诸神的黄昏主题曲）
		Tooltip: 播放“Menu Theme” 作者：CrafterDaemon
	}

	InspirationSingularity.DisplayName: 灵感奇点

	Asterion: {
		DisplayName: 猎犬座阿尔法
		Tooltip:
			'''
			在你周围创造分形星光
			星光击中敌人时有概率给予你星芒
			拥有足够的星芒时，右键创造猎犬座
			猎犬座会迅速消耗星芒，并迅速释放恒星脉冲
			脉冲会治疗你和队友，并对敌人施加[cbuff:CalamityMod/Voidfrost]减益
			“如猎犬般忠诚”
			'''
	}

	FungalCastanets: {
		DisplayName: 真菌响板
		Tooltip:
			'''
			响板有节奏地演奏，喷出缓慢消失的真菌孢子
			右键演奏[c/00FFFF:侵染]！
			当即兴演奏处于激活状态时，你的响板会变成菌生蟹的巨钳，同时召唤孢子倾泻而下
			“听着像是蟹爪的声音！”
			'''
	}

	CantStopWontStop: {
		DisplayName: 根本停不下来
		Tooltip: 这是一首永不停歇的歌……！
	}

	GlacialHarvester: {
		DisplayName: 冰川收割者
		Tooltip:
			'''
			左键旋转镰刀
			右键挥舞镰刀，释放一阵巨大的冰浪
			施加[rbuff:Frostburn]减益
			'''
		Cooldown: 冰川斩正在冷却
	}

	Aphelion: {
		DisplayName: 远日点
		Tooltip:
			'''
			左键旋转镰刀，将附近的敌人拉入旋涡之中
			旋转足够长的时间会召唤出两个绕轨道运行的[c/DDEEFF:恒][c/BCCDEF:星][c/9CACE0:质][c/7B8CD0:量][c/5060BB:体]
			恒星质量体存在时，右键可以把他们的轨道坍缩成超新星
			击中敌人施加[rbuff:CalamityMod/MiracleBlight]减益
			[c/DDEEFF:恒][c/BCCDEF:星][c/9CACE0:质][c/7B8CD0:量][c/5060BB:体]施加[rbuff:CalamityMod/Dragonfire]、[rbuff:CalamityMod/GodSlayerInferno]与[rbuff:CalamityMod/Daybroken]减益
			'''
	}

	Thaumonomicon: {
		DisplayName: 奇迹秘典
		Tooltip: ""
	}
}

