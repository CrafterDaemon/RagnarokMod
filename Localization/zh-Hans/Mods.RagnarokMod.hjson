		RadMage: {
			Label: 光辉法师
			Tooltip:
				'''
				牧师总让人觉得只是另一种法师
				所以我们修正了这一点
				办法就是用牧师取代法师
				只要你信念够坚定，一切魔法都能成为治疗
				或者下手够狠也行。
				'''
		}

		MelSum: {
			Label: 近战召唤
			Tooltip:
				'''
				召唤师的成长路线原本有些尴尬的断档
				所以我们修正了这一点
				办法就是把整个战士都塞给召唤师
				你的召唤物现在会尊敬你
				你的剑不会。
				'''
		}

		RogRan: {
			Label: 盗贼射手
			Tooltip:
				'''
				盗贼正在夺回自己的大本营
				办法就是吞并射手
				反正他们本来就是同一个人
				其中一个只是行头更好一点。
				'''
		}

		ObBard: {
			Label: 没人喜欢吟游诗人
			Tooltip: 使你的即兴演奏……没那么即兴
		}

