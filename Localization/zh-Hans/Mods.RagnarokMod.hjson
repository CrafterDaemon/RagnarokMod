Tooltips: {
	WhiteDwarfSetBonus:
		'''
		盗贼攻击有5%概率从星宇释放象牙状火焰，造成1.75倍伤害
		火焰的伤害基于非暴击伤害，但火焰本身可以暴击
		'''

	LeviathanHeart: {
		NormalTooltip:
			'''
			治疗法术的治疗量提升25%
			治疗法术对目标施加[rbuff:RagnarokMod/LeviathanHeartBubble]增益
			'''
		CorruptTooltip:
			'''
			利维坦泡泡回应了你的暗能量！
			所有生命值消耗减少1点
			消耗生命值会给予你[rbuff:RagnarokMod/LeviathanHeartBubbleCorrupted]增益
			增加10%光辉攻击速度
			'''
	}
}

Compat: {
	TechPoints: 将你的最大技巧值提高
	Recharge: 以及回复速度
	BasicDamage: 基础伤害
	DupeDamage: 的盗贼伤害会被复制
	DupeCap: 复制伤害上限为
	NoGuideStack: 效果不与其他指南叠加
	Power: %威力
	Smited: 被毁灭了。
	Darkness: 坠入黑暗。
	TurnedToAmmo: 被转化为弹药。
	Recoil: 无法承受后坐力。
}

Items: {
	DrumStick: {
		DisplayName: 鼓槌
		Tooltip: “你的敌人就是你的鼓”
	}

	AerospecBard: {
		DisplayName: 天蓝铲帽
		Tooltip:
			'''
			增加5%音波演奏速度和灵感值恢复速度
			咒音增幅持续时间延长2秒
			'''
