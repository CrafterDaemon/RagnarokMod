			增加6%音波伤害
			增加7%移动速度
			'''
	}

	AerospecHealer: {
		DisplayName: 天蓝风帽
		Tooltip:
			'''
			降低10%非光辉伤害
			增加10%光辉伤害
			最大魔力值增加20
			'''
		SetBonus:
			'''
			降低10%非光辉伤害
			增加10%光辉伤害
			一次受到超过25点伤害会召唤追踪羽毛从天而降
			提高下落速度并免疫摔落伤害
			治疗法术会额外治疗2点生命值
			增加10%移动速度
			'''
	}

	AuricTeslaFrilledHelmet: {
		DisplayName: 金缀韵灵盔
		DisplayNameEclipse: 始生金缀韵灵盔
		Tooltip:
			'''
			增加20%音波伤害、音波暴击率和管乐器弹幕追踪速度
			增加5%移动速度
			增加30%灵感值恢复速度
			最大灵感值增加15
			弦乐器的弹幕会额外反弹两次
			'''
		SetBonus:
			'''
			拥有血嚎尖芒盔、弑神者兜帽，和狂想独奏帽/狂想启迪盔的套装效果
			按下'{$ThoriumMod.Keybinds.ArmorAbility.DisplayName}'键将触发两套狂想者套装的效果
			'''
		SetBonusHelheim: 龙蒿、血炎与弑神者套装奖励
	}

	AuricTeslaHealerHead: {
		DisplayName: 金煌圣祗盔
		DisplayNameEclipse: 始生金煌圣祗盔
		Tooltip:
			'''
			腐化你的光辉能量
			增加100%光辉伤害，降低80%非光辉伤害
			增加25%光辉暴击率
			增加5%移动速度
			魔力消耗减少25%
			治疗法术会额外治疗10生命值
			最大魔力值增加100
			'''
		ToggleTooltip: "[c/aaaaaa:在物品栏中按住Shift并右键点击以切换][c/CC44FF:腐化光辉力量]"
		SetBonus:
			'''
			拥有血恸幽冥盔、始源林海覆面，和梦境编织者兜帽/梦境编织者头盔的套装效果
			按下'{$ThoriumMod.Keybinds.ArmorAbility.DisplayName}'键将触发两套梦境编织者套装的效果
			增加50%光辉伤害
			'''
		SetBonusHelheim:
			'''
			龙蒿、血炎与始源林海套装奖励
			增加50%光辉伤害
			'''
	}

	BlazingDrumBeat: {
		DisplayName: 华饰鼓槌
		Tooltip:
			'''
			成功在计时区域击中时，会增加咒音增幅等级和伤害
			错失节拍会大幅降低这些加成并消耗9点灵感值
			这些加成在切换武器后仍会保留，但若此武器不是你的手持武器，加成会逐渐消散
			连续两次或更多次的成功攻击会释放出一道巨大的燃烧斩击
			燃烧斩击会将范围内的所有敌人都施加[cbuff:CalamityMod/HolyFlames]
			'''
	}

	BloodflareHeadBard: {
		DisplayName: 血嚎尖芒盔
		Tooltip:
			'''
			增加20%音波伤害和12%音波暴击率
			增加15%灵感恢复速度和最大灵感值增加6
			增加15%的灵感音符掉率
			'''
		SetBonus:
			'''
			音波伤害会对敌人造成血液沸腾减益
			创造嗜血领域，每次命中敌人获得2点血液，每秒最多获得3次
			血液达到100点时: 增加20%的音波伤害和音波暴击率，增加25%的移动速度
			咒音增幅额外延长3秒，灵感值恢复速度提高10%
			按下“套装奖励”键会消耗20点血液，并补充10点灵感
			被击中将失去25点血液，5秒内未命中敌人会快速失去血液
			每当Boss生成时，你的血液点数会被重置
			'''
	}

	BloodflareHeadHealer: {
		DisplayName: 血恸幽冥盔
		Tooltip:
			'''
			魔力消耗减少20%
			降低70%非光辉伤害，并增加50%光辉伤害
			增加20%光辉暴击率
			治疗法术会额外治疗7生命值
			最大魔力值增加60
			'''
		SetBonus:
			'''
			光辉伤害会对敌人造成血液沸腾减益
			创造嗜血领域，每次命中敌人获得2点血液，每秒最多获得3次
			达到100点时: 增加20%的光辉伤害和光辉暴击率，增加20%的移动速度
			并且你的治疗法术会额外治疗3生命值
			此外，你还会获得相当于造成伤害的一小部分的治疗
			按下“套装奖励”键会消耗20点血液，并获得25点额外治疗量
			被击中将失去25点血液，5秒内未命中敌人会快速失去血液
			每当Boss生成时，你的血液点数会被重置
			'''
	}

