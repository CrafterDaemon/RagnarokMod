Configs: {
	BossProgressionConfig: {
		DisplayName: Boss进程设置
		Headers.BossProgressionChanges: Boss进程改变

		GrandFlareGun: {
			Label: 惊雷王鹰召唤物配方改变
			Tooltip: 辉耀信号枪和风暴信号弹需要风暴之颚，而不是鸟爪，默认为是
		}

		DesertMedallion: {
			Label: 荒漠灾虫召唤物配方改变
			Tooltip: 在荒漠吊坠的配方增加惊雷王鹰掉落的砂石锭，默认为是
		}

		DecapoditaSprout: {
			Label: 菌生蟹召唤物配方改变
			Tooltip: 在节肢动物芽孢的配方增加珍珠碎片和风暴之羽，默认为是
		}

		MarbleGranite: {
			Label: 花岗岩流能风暴/英灵遗骸召唤物配方改变
			Tooltip: 在不稳定核心和上古之剑的配方增加血液样本和德古拉之牙，默认为是
		}

		OverloadedSludge: {
			Label: 史莱姆之神召唤物配方改变
			Tooltip: 在过载凝胶的配方增加赋能花岗岩和魔能大理石. 默认为是
		}

		StarCaller: {
			Label: 星际监察者召唤物配方改变
			Tooltip: 在星空召唤器的配方增加腐烂物质/血液样本. 默认为是
		}

		CryoKey: {
			Label: 极地之灵召唤物配方改变
			Tooltip: 在极寒之匙的配方增加遁蛛冰牙. 默认为是
		}

		MechBosses: {
			Label: 机械Boss召唤物配方改变
			Tooltip: 在机械魔眼、机械蠕虫、机械骷髅王的配方增加奇怪的外星主板. 默认为是
		}

		Lich: {
			Label: 巫妖召唤方式改变
			Tooltip: 需要混乱精华来召唤巫妖而不是南瓜. 默认为是
		}

		CharredIdol: {
			Label: 硫磺火元素召唤物配方改变
			Tooltip: 在焦炭玩偶的配方增加虚空之心. 默认为是
		}

		Seafood: {
			Label: 渊海灾虫召唤物配方改变
			Tooltip: 在海鲜饵料的配方增加水母皇后胶体. 默认为是
		}

		EyeOfDesolation: {
			Label: 灾厄之影召唤物配方改变
			Tooltip: 在荒芜之眼的配方增加虚兆珠. 默认为是
		}

		DeathWhistle: {
			Label: 毁灭魔像召唤物配方改变
			Tooltip: 在唤死笛哨的配方增加诅咒布匹. 默认为是
		}

		DoomSayerCoin: {
			Label: 始生灾灵召唤物配方改变
			Tooltip: 在末日预言者的硬币的配方增加灾厄尘. 默认为是
		}

		RuneOfKos: {
			Label: 宇宙符文获取改变
			Tooltip: 将普罗维登斯神印改为需要神圣晶石与始生灾灵精华并不再由亵渎天神掉落。默认为是。
		}
	}

	ClassBalancerConfig: {
		DisplayName: 职业平衡设置

		Headers: {
			ClassBalanceChanges: 职业平衡设置页
			ClassMechanicChanges: 职业机制切换
		}

		HealerDamageModifier: {
			Label: 牧师伤害倍率
			Tooltip: 牧师伤害倍率，倍率在其他变化加成后才会生效。
		}

		BardDamageModifier: {
			Label: 吟游诗人伤害倍率
			Tooltip: 吟游诗人伤害倍率，倍率在其他变化加成后才会生效。
		}

		RogueDamageModifier: {
			Label: 盗贼伤害倍率
			Tooltip: 盗贼或投手伤害倍率，倍率在其他变化加成后才会生效。
		}

		RangedDamageModifier: {
			Label: 远程伤害倍率
			Tooltip: 远程伤害倍率，倍率在其他变化加成后才会生效。
		}

		MagicDamageModifier: {
			Label: 法师伤害倍率
			Tooltip: 法师伤害倍率，倍率在其他变化加成后才会生效。
		}

		SummonDamageModifier: {
			Label: 召唤伤害倍率
			Tooltip: 召唤伤害倍率，倍率在其他变化加成后才会生效。
		}

		MeleeDamageModifier: {
			Label: 近战伤害倍率
			Tooltip: 近战伤害倍率，倍率在其他变化加成后才会生效。
		}

		HealingBonusModifier: {
			Label: 额外治疗量倍率
			Tooltip: 额外治疗量倍率。该倍数在所有其他改动应用后生效。
		}

		RiffsRequireRiffInstrumentToBeHeld: {
			Label: 即兴演奏要求玩家持续手持对应乐器
			Tooltip: 玩家切换武器时，即兴演奏自动停止。
		}

		MistimedDamagePen: {
			Label: 错失时机的伤害惩罚
			Tooltip:
				'''
				瑟银MOD中大型乐器因错失时机而造成的伤害惩罚。
				瑟银MOD的默认值为0.75，这意味着时机不当的攻击造成的伤害会减少75%。
				诸神黄昏MOD的默认值为0.6，这意味着时机不当的攻击造成的伤害会减少60%。
				[c/7C0A02:但是部分模组会强制修改该值以适配他们自己的平衡]
				'''
		}
	}

	ItemBalancerConfig: {
		DisplayName: 物品平衡设置
		Headers.ItemBalanceChanges: 物品平衡更改页

		OmegaCore: {
			Label: 欧米伽核心
			Tooltip: 降低了奥米茄核心的速度加成，让该物品在游戏里面更加平衡，从而促进游戏发展。
